{
  "name": "english-exercises-proto",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:back\" \"npm run dev:front\"",
    "dev:back": "npm run start:dev --workspace=api",
    "dev:front": "npm run dev --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
