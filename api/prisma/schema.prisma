generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TestStatus {
  draft
  parsing
  published
  failed_parse
}

model Test {
  id               String         @id @default(cuid())
  title            String
  status           TestStatus     @default(draft)
  sourceFilename   String?
  errorMessage     String?
  createdAt        DateTime       @default(now())
  parsedAt         DateTime?
  questions        TestQuestion[]
  sourceFiles      TestSourceFile[]
}

model TestSourceFile {
  id         String @id @default(cuid())
  testId     String
  test       Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  storageKey String
  mime       String
  sizeBytes  Int

  @@index([testId])
}

model TestQuestion {
  id        String               @id @default(cuid())
  testId    String
  test      Test                 @relation(fields: [testId], references: [id], onDelete: Cascade)
  sortOrder Int
  clientKey String
  prompt    String
  /// Optional hints when the learner picks a wrong option: [{ "option": "a", "text": "..." }]
  hint      Json?
  choices   TestQuestionChoice[]

  @@unique([testId, clientKey])
  @@index([testId])
}

model TestQuestionChoice {
  id         String       @id @default(cuid())
  questionId String
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  key        String
  text       String
  isCorrect  Boolean      @default(false)

  @@unique([questionId, key])
  @@index([questionId])
}
